# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/tamper_log

# ─── Logging ──────────────────────────────────────────────────────────────────
# Valid values: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── Security ─────────────────────────────────────────────────────────────────
# Required: secret key checked against x-api-key header on all /api/* routes
API_KEY=change-me-to-a-long-random-secret

# Allowed CORS origin (* = allow all, not recommended in production)
CORS_ORIGIN=*

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Defaults: 100 requests per 60000ms (1 minute) per IP
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Docker Compose ───────────────────────────────────────────────────────────
POSTGRES_USER=log_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tamper_log
