generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A single immutable audit log record. Records are append-only;
/// the schema has no updatedAt field and no soft-delete support.
model LogEntry {
  /// UUID v4 primary key — auto-generated by the database.
  /// UUIDs prevent sequential ID enumeration by external callers.
  id String @id @default(uuid())

  /// The identity of the entity (user, service, or system component)
  /// that created this log entry. Maximum 255 characters.
  actor String @db.VarChar(255)

  /// A short descriptor of the event being logged
  /// (e.g. 'user.login', 'order.placed'). Maximum 500 characters.
  action String @db.VarChar(500)

  /// Optional structured metadata associated with the event.
  /// Stored as a JSON column; null when no metadata was provided.
  payload Json?

  /// The currentHash of the immediately preceding LogEntry in the chain.
  /// Null for the genesis (first) entry which has no predecessor.
  /// This field links the hash chain and enables tamper detection.
  previousHash String?

  /// SHA-256 hex digest of this entry's content (including previousHash).
  /// Unique across the entire log. VarChar(128) accommodates SHA-256
  /// (64 hex chars) with headroom for future algorithm upgrades.
  currentHash String @unique @db.VarChar(128)

  /// The UTC timestamp at which this entry was inserted.
  /// Set automatically by the database; never updated.
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  /// Index on createdAt supports efficient ascending chain traversal
  /// and range queries without a full table scan.
  @@index([createdAt])

  @@map("log_entries")
}
