{
  "name": "tamper-evident-log-service",
  "version": "1.0.0",
  "description": "A production-ready tamper-evident append-only log service with cryptographic hash chaining",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "eslint src --ext .js",
    "format": "prettier --write \"src/**/*.js\"",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "docker:build": "docker build -t tamper-evident-log-service .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@prisma/client": "6.16.3",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-rate-limit": "7.1.5",
    "helmet": "7.1.0",
    "pino": "8.17.2",
    "pino-http": "9.0.0",
    "pino-pretty": "10.3.1",
    "prisma": "6.16.3",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "eslint": "8.56.0",
    "eslint-config-prettier": "9.1.0",
    "fast-check": "3.15.0",
    "jest": "29.7.0",
    "nodemon": "3.0.2",
    "prettier": "3.2.2",
    "supertest": "6.3.4"
  }
}
